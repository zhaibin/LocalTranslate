# Ollama server and model used by the CLI, HTTP API, and MCP server.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=translategemma:latest

# Default language codes used when a request omits source_lang or target_lang.
DEFAULT_SOURCE_LANG=en
DEFAULT_TARGET_LANG=zh

# Timeout for Ollama generation requests.
REQUEST_TIMEOUT_SECONDS=120
